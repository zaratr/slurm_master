#!/usr/bin/env bash
set -euo pipefail

partition="eda"
name="lsf-job"
cpus=1
mem="512M"
license=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -q) partition="$2"; shift 2 ;;
    -J) name="$2"; shift 2 ;;
    -n) cpus="$2"; shift 2 ;;
    -M) mem="${2}M"; shift 2 ;;
    -R)
      if [[ "$2" =~ mem=([0-9]+) ]]; then mem="${BASH_REMATCH[1]}M"; fi
      shift 2 ;;
    -lic|-L)
      license="$2"; shift 2 ;;
    --)
      shift; break ;;
    -*)
      echo "bsub wrapper does not support option: $1" >&2
      exit 2 ;;
    *)
      break ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "Usage: bsub [-q queue] [-J name] [-n cores] [-M mb] [-lic feature:count] command..." >&2
  exit 2
fi

args=(--partition "$partition" --job-name "$name" --cpus-per-task "$cpus" --mem "$mem" --output "/logs/jobs/slurm-%j.out" --wrap "$*")
if [[ -n "$license" ]]; then
  args=(--licenses "$license" "${args[@]}")
fi

sbatch "${args[@]}"
